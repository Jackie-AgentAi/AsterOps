    "lodash-es": "^4.17.21",
    "nprogress": "^0.2.0",
    "js-cookie": "^3.0.5",
    "mitt": "^3.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.5.2",

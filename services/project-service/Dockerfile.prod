# 项目管理服务生产环境Dockerfile
# 多阶段构建，优化镜像大小和安全性

# ===================
# 构建阶段
# ===================
FROM golang:1.21-alpine AS builder

# 设置阿里云镜像源
RUN sed -i 's/dl-cdn.alpinelinux.org/mirrors.aliyun.com/g' /etc/apk/repositories

# 设置工作目录
WORKDIR /app

# 安装必要的包
RUN apk add --no-cache \
    git \
    ca-certificates \
    tzdata \
    make \
    gcc \
    musl-dev

# 设置Go环境变量
ENV GO111MODULE=on
ENV GOPROXY=https://goproxy.cn,direct
ENV GOSUMDB=sum.golang.google.cn
ENV CGO_ENABLED=0
ENV GOOS=linux
ENV GOARCH=amd64

# 复制go mod文件
COPY go.mod go.sum ./

# 下载依赖
RUN go mod download

# 复制源代码
COPY . .

# 构建应用
RUN go build -a -installsuffix cgo -ldflags='-w -s -extldflags "-static"' -o main cmd/server/main.go

# ===================
# 运行阶段
# ===================
FROM gcr.io/distroless/static-debian11:nonroot

# 设置时区
ENV TZ=Asia/Shanghai

# 设置工作目录
WORKDIR /app

# 从构建阶段复制二进制文件
COPY --from=builder /app/main /app/main

# 复制配置文件
COPY --from=builder /app/configs /app/configs

# 设置文件权限
RUN chmod +x /app/main

# 暴露端口
EXPOSE 8082

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD ["/app/main", "health"]

# 启动应用
ENTRYPOINT ["/app/main"]
